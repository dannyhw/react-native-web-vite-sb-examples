{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "paths": {
      "@components/*": ["components/*"] // enables us to use @components/MyComponent
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    ".rnstorybook/**/*.ts",
    ".rnstorybook/**/*.tsx"
  ]
}
